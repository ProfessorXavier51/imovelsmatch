# ============================================
# 🚫 GITIGNORE - Frontend Next.js
# ============================================
#
# 🎯 O QUE ESTE ARQUIVO FAZ?
# Lista arquivos/pastas que o Git deve ignorar.
#
# 📚 ANALOGIA: LISTA DE "NÃO LEVAR" 🚫
# - Não commitar node_modules (muito pesado)
# - Não commitar .env (segurança)
# - Não commitar builds (.next)
#
# 🤔 POR QUÊ PRECISAMOS DISSO?
# - Repositório mais leve
# - Segurança (não expor secrets)
# - Evitar conflitos
#
# ⏰ QUANDO É USADO?
# - Ao fazer git add
# - Ao fazer git commit
# ============================================

# ========================================
# 📦 DEPENDENCIES (Dependências)
# ========================================
node_modules/
.pnp
.pnp.js

# ========================================
# 🧪 TESTING (Testes)
# ========================================
coverage/
*.lcov
.nyc_output

# ========================================
# 🏗️ BUILD (Next.js)
# ========================================
.next/
out/
build/
dist/

# ========================================
# 🔐 ENV (Variáveis de Ambiente)
# ========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ========================================
# 📝 LOGS (Arquivos de Log)
# ========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ========================================
# 💻 EDITOR (IDEs)
# ========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ========================================
# ⚡ VERCEL (Deploy)
# ========================================
.vercel

# ========================================
# 📊 TYPESCRIPT
# ========================================
*.tsbuildinfo
next-env.d.ts

# ========================================
# 🎨 MISC
# ========================================
.turbo
.cache

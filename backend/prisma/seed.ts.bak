// ============================================
// 📦 SEEDER: prisma/seed.ts
// ============================================
// 🎯 O QUE? Popula banco com dados de teste para CRM
// 📊 QUANTIDADE: 10 clientes + 10 imóveis + 4 matches perfeitos
// 🚀 COMO? npx prisma db seed
// ============================================

import { PrismaClient, TipoInteresse, TipoOperacao, TipoImovel } from '@prisma/client';
import * as bcrypt from 'bcryptjs';

const prisma = new PrismaClient();


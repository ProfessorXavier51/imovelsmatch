# ============================================
# VARIÁVEIS DE AMBIENTE - IMOVELSMATCH BACKEND
# ============================================
#
# 🎯 O QUE É ESTE ARQUIVO?
# Guarda informações secretas e configurações
#
# 📚 ANALOGIA: É como sua CARTEIRA
# - Tem suas senhas (não mostra para ninguém)
# - Tem seus cartões (informações importantes)
# - Você não deixa na rua (não commita no Git)
#
# ⚠️ IMPORTANTE:
# Este arquivo .env NÃO deve ser commitado no Git!
# Está no .gitignore para sua segurança
# ============================================

# ============================================
# BANCO DE DADOS (MySQL)
# ============================================
# 🗄️ URL de conexão com o banco MySQL
#
# 📝 FORMATO:
# mysql://usuario:senha@host:porta/nome_banco
#
# 📚 ANALOGIA: É como o ENDEREÇO COMPLETO da sua casa
# - usuario = Seu nome (quem mora)
# - senha = Chave da porta
# - host = Rua (localhost = sua própria máquina)
# - porta = Número da casa (3306 = padrão MySQL)
# - nome_banco = Apartamento (qual banco usar)
#
# 🔧 CONFIGURAÇÃO PADRÃO (Desenvolvimento):
DATABASE_URL="mysql://root:root@localhost:3306/imovelsmatch"

# 💡 DICA: Se sua senha do MySQL for diferente, mude aqui:
# DATABASE_URL="mysql://root:SUA_SENHA@localhost:3306/imovelsmatch"

# ============================================
# JWT (Autenticação)
# ============================================
# 🔐 Chave secreta para assinar tokens
#
# 📚 ANALOGIA: É como a RECEITA SECRETA da Coca-Cola
# - Ninguém pode saber
# - Única no mundo
# - Protege sua aplicação
#
# 🔧 COMO GERAR UMA CHAVE SEGURA?
# No terminal, rode:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="mude-isso-para-uma-chave-super-secreta-e-aleatoria"

# ⏰ Tempo que o token dura
# Exemplos: 1h, 7d, 30d
JWT_EXPIRES_IN="7d"

# ============================================
# REDIS (Filas e Cache)
# ============================================
# 🚀 Servidor Redis (para filas de jobs)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ============================================
# E-MAIL (SMTP)
# ============================================
# 📧 Configurações para enviar e-mails
#
# 📚 ANALOGIA: É como configurar seu e-mail no celular
# - Precisa do servidor (Gmail, Outlook, etc)
# - Precisa da porta
# - Precisa do seu e-mail e senha
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-ou-app-password"
SMTP_FROM="ImoveisMatch <noreply@imovelsmatch.com>"

# ============================================
# CLOUDINARY (Upload de Imagens)
# ============================================
# 🖼️ Serviço para guardar fotos dos imóveis
#
# 📚 ANALOGIA: É como o Google Fotos
# - Você faz upload das fotos
# - Eles guardam na nuvem
# - Você pega o link para mostrar
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="seu-api-secret"
CLOUDINARY_FOLDER="imovelsmatch"

# ============================================
# WHATSAPP (Notificações)
# ============================================
# 📱 Qual serviço de WhatsApp usar
# Opções: evolution, cloud-api, ultramsg, twilio
WHATSAPP_PROVIDER="evolution"

# Evolution API
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua-api-key"
EVOLUTION_INSTANCE="imovelsmatch"

# ============================================
# APLICAÇÃO
# ============================================
# Porta do servidor backend
PORT=3001

# Ambiente (development, production, test)
NODE_ENV=development

# URL do frontend (para CORS)
FRONTEND_URL="http://localhost:3000"

# JWT Secret Key
JWT_SECRET="imovelsmatch-super-secret-key-change-in-production-2024"

# ============================================
# CLOUDINARY (Upload de Imagens)
# ============================================
# 📸 Configurações do Cloudinary
# Cadastre-se em: https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================
# LIMITES
# ============================================
# 📊 Configurações de limites
MAX_NOTIFICATIONS_PER_DAY=3
MAX_UPLOAD_SIZE_MB=10
MAX_PHOTOS_PER_IMOVEL=20

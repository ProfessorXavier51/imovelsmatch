# ============================================
# VARIÁVEIS DE AMBIENTE - IMOVELSMATCH BACKEND
# ============================================
#
# Como usar?
# 1. Copie este arquivo para .env
# 2. Preencha os valores reais
# 3. NUNCA commite o arquivo .env (está no .gitignore)
#
# Por quê usar .env?
# - Segurança: Senhas não ficam no código
# - Flexibilidade: Valores diferentes por ambiente
# - Boas práticas: Separação de configuração e código
# ============================================

# ============================================
# BANCO DE DADOS (MySQL)
# ============================================
# URL de conexão com o banco MySQL
# Formato: mysql://usuario:senha@host:porta/nome_banco
# Exemplo: mysql://root:senha123@localhost:3306/imovelsmatch
DATABASE_URL="mysql://root:senha@localhost:3306/imovelsmatch"

# ============================================
# JWT (Autenticação)
# ============================================
# Secret para assinar tokens JWT
# IMPORTANTE: Use uma string aleatória e complexa
# Como gerar? node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="seu-secret-super-secreto-aqui-mude-isso"

# Tempo de expiração do token
# Exemplos: 1h, 7d, 30d
# Por quê? Tokens não devem durar para sempre
JWT_EXPIRES_IN="7d"

# ============================================
# REDIS (Filas e Cache)
# ============================================
# Host do Redis
# Desenvolvimento: localhost
# Produção: IP do servidor Redis
REDIS_HOST="localhost"

# Porta do Redis
# Padrão: 6379
REDIS_PORT=6379

# Senha do Redis (opcional)
# Deixe vazio se não tiver senha
REDIS_PASSWORD=""

# ============================================
# E-MAIL (SMTP)
# ============================================
# Host do servidor SMTP
# Gmail: smtp.gmail.com
# Outlook: smtp-mail.outlook.com
SMTP_HOST="smtp.gmail.com"

# Porta SMTP
# TLS: 587
# SSL: 465
SMTP_PORT=587

# Usuário (e-mail)
SMTP_USER="seu-email@gmail.com"

# Senha ou App Password
# Gmail: Use App Password (https://myaccount.google.com/apppasswords)
# Por quê? Mais seguro que senha normal
SMTP_PASS="sua-senha-ou-app-password"

# E-mail remetente (From)
# Aparece como remetente nos e-mails
SMTP_FROM="ImoveisMatch <noreply@imovelsmatch.com>"

# ============================================
# CLOUDINARY (Upload de Imagens)
# ============================================
# Nome da cloud no Cloudinary
# Onde encontrar? Dashboard do Cloudinary
CLOUDINARY_CLOUD_NAME="seu-cloud-name"

# API Key do Cloudinary
CLOUDINARY_API_KEY="sua-api-key"

# API Secret do Cloudinary
# IMPORTANTE: Mantenha secreto
CLOUDINARY_API_SECRET="seu-api-secret"

# Pasta padrão para uploads
# Por quê? Organização das imagens
CLOUDINARY_FOLDER="imovelsmatch"

# ============================================
# WHATSAPP (Notificações)
# ============================================
# Provider ativo
# Opções: evolution, cloud-api, ultramsg, twilio
# Por quê? Sistema suporta múltiplos providers
WHATSAPP_PROVIDER="evolution"

# ============================================
# WHATSAPP - EVOLUTION API
# ============================================
# URL da API Evolution
# Exemplo: http://localhost:8080
EVOLUTION_API_URL="http://localhost:8080"

# API Key da Evolution
EVOLUTION_API_KEY="sua-api-key-evolution"

# Nome da instância
# Onde criar? Painel da Evolution API
EVOLUTION_INSTANCE="imovelsmatch"

# ============================================
# WHATSAPP - CLOUD API (Meta/Facebook)
# ============================================
# Token de acesso
# Onde obter? Meta for Developers
CLOUD_API_TOKEN="seu-token-cloud-api"

# Phone Number ID
# Onde obter? WhatsApp Business API
CLOUD_API_PHONE_ID="seu-phone-number-id"

# ============================================
# WHATSAPP - ULTRAMSG
# ============================================
# Token da UltraMsg
# Onde obter? https://ultramsg.com
ULTRAMSG_TOKEN="seu-token-ultramsg"

# Instance ID
ULTRAMSG_INSTANCE="seu-instance-id"

# ============================================
# WHATSAPP - TWILIO
# ============================================
# Account SID do Twilio
# Onde obter? Console do Twilio
TWILIO_ACCOUNT_SID="seu-account-sid"

# Auth Token do Twilio
TWILIO_AUTH_TOKEN="seu-auth-token"

# Número WhatsApp do Twilio
# Formato: whatsapp:+5511999999999
TWILIO_WHATSAPP_NUMBER="whatsapp:+5511999999999"

# ============================================
# APLICAÇÃO
# ============================================
# Porta do servidor
# Padrão: 3001 (frontend usa 3000)
PORT=3001

# Ambiente
# Opções: development, production, test
# Por quê? Comportamentos diferentes por ambiente
NODE_ENV="development"

# URL do frontend (CORS)
# Usado para configurar CORS
# Desenvolvimento: http://localhost:3000
# Produção: https://seudominio.com
FRONTEND_URL="http://localhost:3000"

# ============================================
# LIMITES E CONFIGURAÇÕES
# ============================================
# Limite de notificações por cliente por dia
# Por quê? Evitar spam
# Padrão: 3 notificações/dia
MAX_NOTIFICATIONS_PER_DAY=3

# Tamanho máximo de upload (em MB)
# Por quê? Controlar uso de espaço
MAX_UPLOAD_SIZE_MB=10

# Número máximo de fotos por imóvel
# Por quê? Limitar uso de storage
MAX_PHOTOS_PER_IMOVEL=20
